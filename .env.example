# Public (client-exposed) variables
# NEXT_PUBLIC_APP_URL=https://localhost:3000

# Server-only variables (add when integrating Clerk, Convex, etc.)
# CLERK_SECRET_KEY=
# CONVEX_DEPLOYMENT=

# Waitlist → Resend (https://resend.com/docs/knowledge-base/what-email-addresses-to-use-for-testing)
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_AUDIENCE_ID=audience-uuid-from-resend-dashboard
# Optional: verified domain sender. If omitted, welcome email uses Resend test sender onboarding@resend.dev — Resend only delivers those to your Resend account email until you verify a domain (resend.com/domains).
# RESEND_FROM_EMAIL="Ayati <waitlist@yourdomain.com>"
# Required for signing unsubscribe links (min 16 characters)
# WAITLIST_UNSUBSCRIBE_SECRET=use-a-long-random-secret-here
